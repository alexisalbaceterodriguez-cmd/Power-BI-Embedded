# ─── Azure AD / Service Principal ───────────────────────────────────
AZURE_TENANT_ID="<tenant-guid>"
AZURE_CLIENT_ID="<app-registration-client-id>"
AZURE_CLIENT_SECRET="<app-registration-client-secret>"

# ─── Auth.js / NextAuth ────────────────────────────────────────────
NEXTAUTH_SECRET="<random-32-plus-chars>"
NEXTAUTH_URL="http://localhost:3000"
AUTH_MICROSOFT_ENTRA_ID_ID="<entra-client-id>"
AUTH_MICROSOFT_ENTRA_ID_SECRET="<entra-client-secret>"
AUTH_MICROSOFT_ENTRA_ID_ISSUER="https://login.microsoftonline.com/<tenant-guid>/v2.0"

# ─── Azure SQL ─────────────────────────────────────────────────────
AZURE_SQL_SERVER="<server>.database.windows.net"
AZURE_SQL_DATABASE="powerbiembedded"
AZURE_SQL_AUTH_MODE="azure-default"
# Only needed if AZURE_SQL_AUTH_MODE=sql:
# AZURE_SQL_USER="<sql-admin-user>"
# AZURE_SQL_PASSWORD="<sql-admin-password>"
AZURE_SQL_ENCRYPT="true"
AZURE_SQL_TRUST_SERVER_CERTIFICATE="false"

# ─── Bootstrap data (first-run seed) ──────────────────────────────
BOOTSTRAP_ADMIN_USERNAME="admin"
BOOTSTRAP_ADMIN_EMAIL="admin@contoso.com"
BOOTSTRAP_REPORTS_JSON='[{"id":"finance","displayName":"Finance","clientId":"cliente-1","workspaceId":"<workspace-guid>","reportId":"<report-guid>","rlsRoles":["Empresa 01"]}]'
BOOTSTRAP_USERS_JSON='[{"username":"cliente_finance","email":"cliente@contoso.com","role":"client","reportIds":["finance"],"rlsRoles":["Empresa 01"]}]'
BOOTSTRAP_AI_AGENTS_JSON='[{"name":"agent-sales","responsesEndpoint":"https://api.fabric.microsoft.com/v1/mcp/workspaces/<workspace-guid>/dataagents/<agent-guid>/agent","securityMode":"none","reportIds":["finance"],"isActive":true}]'

# ─── Fabric Data Agent runtime ─────────────────────────────────────
FOUNDRY_API_SCOPE="https://api.fabric.microsoft.com/.default"
FOUNDRY_AUTH_MODE="azure-cli"
