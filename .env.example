# Azure credentials (canonical)
AZURE_TENANT_ID="<tenant-guid>"
AZURE_CLIENT_ID="<app-registration-client-id>"
AZURE_CLIENT_SECRET="<app-registration-client-secret>"

# Legacy compatibility (optional during migration)
# TENANT_ID="<tenant-guid>"
# CLIENT_ID="<app-registration-client-id>"
# CLIENT_SECRET="<app-registration-client-secret>"

# Auth.js / NextAuth
NEXTAUTH_SECRET="<random-32-plus-chars>"
NEXTAUTH_URL="https://your-domain"
# Optional explicit Entra config if different from AZURE_* values
# AUTH_MICROSOFT_ENTRA_ID_ID="<entra-client-id>"
# AUTH_MICROSOFT_ENTRA_ID_SECRET="<entra-client-secret>"
# AUTH_MICROSOFT_ENTRA_ID_ISSUER="https://login.microsoftonline.com/<tenant-guid>/v2.0"

# Data layer
APP_DB_PATH="./data/security.db"

# Azure SQL (for local work against Azure DB)
AZURE_SQL_SERVER="<server>.database.windows.net"
AZURE_SQL_DATABASE="powerbiembedded"
AZURE_SQL_AUTH_MODE="azure-default"
AZURE_SQL_USER="<sql-admin-user>"
AZURE_SQL_PASSWORD="<sql-admin-password>"
AZURE_SQL_ENCRYPT="true"
AZURE_SQL_TRUST_SERVER_CERTIFICATE="false"

# Optional bootstrap (passwordless)
BOOTSTRAP_ADMIN_USERNAME="admin"
BOOTSTRAP_ADMIN_EMAIL="admin@contoso.com"
BOOTSTRAP_REPORTS_JSON='[{"id":"finance","displayName":"Finance","workspaceId":"<workspace-guid>","reportId":"<report-guid>","rlsRoles":["Empresa 01"]}]'
BOOTSTRAP_USERS_JSON='[{"username":"cliente_finance","email":"cliente@contoso.com","role":"client","reportIds":["finance"],"rlsRoles":["Empresa 01"]}]'
BOOTSTRAP_AI_AGENTS_JSON='[{"name":"agent_sales_dataset","publishedUrl":"https://api.fabric.microsoft.com/v1/...","mcpUrl":"https://api.fabric.microsoft.com/v1/mcp/...","mcpToolName":"DataAgent_agent_sales_dataset","reportIds":["finance"],"isActive":true}]'

# Fabric
FABRIC_API_SCOPE="https://api.fabric.microsoft.com/.default"
FABRIC_ENABLE_MCP_FALLBACK="false"
