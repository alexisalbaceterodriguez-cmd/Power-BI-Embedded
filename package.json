{
  "name": "powerbi-embedded",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "fabric:health": "node --env-file=.env.local scripts/fabric-health-check.mjs",
    "db:azure:init": "node --env-file=.env.local scripts/init-azure-sql.mjs",
    "db:azure:seed": "node --env-file=.env.local scripts/seed-azure-sql.mjs",
    "foundry:py:install": "python -m pip install -r requirements-foundry.txt",
    "foundry:py:invoke": "python scripts/invoke_foundry_agent.py --env-file .env.local",
    "foundry:py:invoke:verbose": "python scripts/invoke_foundry_agent.py --env-file .env.local --verbose"
  },
  "dependencies": {
    "mssql": "^11.0.1",
    "next": "16.2.0",
    "next-auth": "^5.0.0-beta.30",
    "powerbi-client": "^2.23.10",
    "powerbi-client-react": "^2.0.2",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/mssql": "^9.1.11",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
